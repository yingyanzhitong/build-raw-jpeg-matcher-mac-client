{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "照片配对助手",
  "version": "0.1.16",
  "identifier": "com.masongzhi.rawjpegmatcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "照片配对助手",
        "width": 1180,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/raw-jpeg-matcher-thumbnails/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFQTgxOUQyN0YzOUVEMzAKUldRdzdUbC8waG1vM2dzUzNxa0huTG9iUk1YVm9Ra0hqcVplSldlWGRJa0NCMTFoKzk1dWlIOFMK",
      "endpoints": [
        "https://gitee.com/masongzhi1/raw-jpeg-matcher-mac-client/raw/main/release/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

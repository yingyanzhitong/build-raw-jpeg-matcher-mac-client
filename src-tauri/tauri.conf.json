{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RAW JPEG Matcher",
  "version": "0.1.1",
  "identifier": "com.bigo.rawjpegmatcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RAW JPEG Matcher",
        "width": 1180,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"]
  }
}
